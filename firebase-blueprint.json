{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A product available in the store.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "brand": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "image": { "type": "string", "format": "uri" },
        "rating": { "type": "number" },
        "discount": { "type": "number" },
        "gender": { "type": "string", "enum": ["Men", "Women", "Unisex", "Kids"] },
        "sizes": { "type": "array", "items": { "type": "string" } },
        "colors": { "type": "array", "items": { "type": "string" } },
        "isPrime": { "type": "boolean" }
      },
      "required": ["name", "brand", "price", "category", "image", "rating", "gender", "sizes", "colors"]
    },
    "User": {
      "title": "User",
      "description": "A user profile.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role", "createdAt"]
    },
    "CartItem": {
      "title": "Cart Item",
      "description": "An item in a user's cart.",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "quantity": { "type": "number" },
        "selectedSize": { "type": "string" },
        "selectedColor": { "type": "string" }
      },
      "required": ["productId", "quantity"]
    },
    "Order": {
      "title": "Order",
      "description": "A completed order.",
      "type": "object",
      "properties": {
        "items": { 
          "type": "array", 
          "items": { "$ref": "#/entities/CartItem" } 
        },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["items", "totalAmount", "status", "createdAt"]
    },
    "Review": {
      "title": "Review",
      "description": "A product review.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "rating": { "type": "number" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userName", "rating", "text", "createdAt"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": { "$ref": "#/entities/Product" },
      "description": "The catalog of products."
    },
    "/products/{productId}/reviews/{reviewId}": {
      "schema": { "$ref": "#/entities/Review" },
      "description": "Product reviews."
    },
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles."
    },
    "/users/{userId}/cart/{cartItemId}": {
      "schema": { "$ref": "#/entities/CartItem" },
      "description": "User's shopping cart items."
    },
    "/users/{userId}/orders/{orderId}": {
      "schema": { "$ref": "#/entities/Order" },
      "description": "User's order history."
    }
  }
}
